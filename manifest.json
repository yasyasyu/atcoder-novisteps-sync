{
  "manifest_version": 3,
  "name": "AtCoder NoviSteps Auto Sync",
  "version": "1.1",
  "content_scripts": [
    {
      "matches": [
        "https://atcoder-novisteps.vercel.app/workbooks/*",
        "https://atcoder-novisteps.vercel.app/problems*"
      ],
      "js": ["content.js"]
    }
  ],
  "host_permissions": ["https://kenkoooo.com/*"],
  "permissions": ["storage"]
}
